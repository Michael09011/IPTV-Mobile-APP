<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Include all shared preferences -->
        <include domain="sharedpref" path="." />
        <!-- Include all databases -->
        <include domain="database" path="." />
        <!-- Exclude cache files -->
        <exclude domain="file" path="cache/" />
    </cloud-backup>
    <device-transfer>
        <!-- Include all shared preferences -->
        <include domain="sharedpref" path="." />
        <!-- Include all databases -->
        <include domain="database" path="." />
        <!-- Exclude cache files -->
        <exclude domain="file" path="cache/" />
    </device-transfer>
</data-extraction-rules>
